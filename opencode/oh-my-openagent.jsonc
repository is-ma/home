{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1
    },
    "atlas": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2
    },
    "prometheus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15
    },
    "metis": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.5
    },
    "momus": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.05
    },
    "multimodal-looker": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.05
    },
    "oracle": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1
    },
    "hephaestus": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.35
    },
    "explore": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.05
    },
    "librarian": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.05
    },
    "sisyphus-junior": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.3
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.5
    },
    "ultrabrain": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.4
    },
    "deep": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.5
    },
    "artistry": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.65
    },
    "quick": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1
    },
    "unspecified-low": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1
    },
    "unspecified-high": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.45
    },
    "writing": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.55
    }
  },
  "background_task": {
    "defaultConcurrency": 15,
    "modelConcurrency": {
      "deepseek/deepseek-v4-pro": 20,
      "deepseek/deepseek-v4-flash": 1000
    }
  },
  "experimental": {
    "disable_omo_env": true
  }
}
