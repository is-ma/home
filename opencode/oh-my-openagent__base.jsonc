{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "$OMO_AGENT__SISYPHUS",
      "temperature": 0.1
    },
    "atlas": {
      "model": "$OMO_AGENT__ATLAS",
      "temperature": 0.2
    },
    "prometheus": {
      "model": "$OMO_AGENT__PROMETHEUS",
      "temperature": 0.15
    },
    "metis": {
      "model": "$OMO_AGENT__METIS",
      "temperature": 0.5
    },
    "momus": {
      "model": "$OMO_AGENT__MOMUS",
      "temperature": 0.05
    },
    "multimodal-looker": {
      "model": "$OMO_AGENT__MULTIMODAL_LOOKER",
      "temperature": 0.05
    },
    "oracle": {
      "model": "$OMO_AGENT__ORACLE",
      "temperature": 0.1
    },
    "hephaestus": {
      "model": "$OMO_AGENT__HEPHAESTUS",
      "temperature": 0.35
    },
    "explore": {
      "model": "$OMO_AGENT__EXPLORE",
      "temperature": 0.05
    },
    "librarian": {
      "model": "$OMO_AGENT__LIBRARIAN",
      "temperature": 0.05
    },
    "sisyphus-junior": {
      "model": "$OMO_AGENT__SISYPHUS_JUNIOR",
      "temperature": 0.3
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "$OMO_CATEGORY__VISUAL_ENGINEERING",
      "temperature": 0.5
    },
    "ultrabrain": {
      "model": "$OMO_CATEGORY__ULTRABRAIN",
      "temperature": 0.4
    },
    "deep": {
      "model": "$OMO_CATEGORY__DEEP",
      "temperature": 0.5
    },
    "artistry": {
      "model": "$OMO_CATEGORY__ARTISTRY",
      "temperature": 0.65
    },
    "quick": {
      "model": "$OMO_CATEGORY__QUICK",
      "temperature": 0.1
    },
    "unspecified-low": {
      "model": "$OMO_CATEGORY__UNSPECIFIED_LOW",
      "temperature": 0.1
    },
    "unspecified-high": {
      "model": "$OMO_CATEGORY__UNSPECIFIED_HIGH",
      "temperature": 0.45
    },
    "writing": {
      "model": "$OMO_CATEGORY__WRITING",
      "temperature": 0.55
    }
  },
  "experimental": {
    "disable_omo_env": true
  }
}
