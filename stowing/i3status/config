# i3status configuration file.
# see "man i3status" for documentation.

general {
        colors = true
        interval = 5
}

#order += "ipv6"
order += "wireless _first_"
#order += "ethernet _first_"
order += "battery all"
#order += "disk /"
#order += "load"
order += "memory"
order += "tztime local"

wireless _first_ {
        format_up = "%essid %quality"
        format_down = "W:down"
}

ethernet _first_ {
        format_up = "E:up"
        format_down = "E:down"
}

battery all {
        format = "%status %percentage"
}

disk "/" {
        format = "%avail"
}

load {
        format = "%1min"
}

memory {
        format = "RAM: %used"
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

tztime local {
        format = "%A %d/%b %H:%M:%S"
}
