# Dunst config - user overrides
# Everything not specified here uses dunst's compiled defaults

[global]
    # Copying key visual settings from system default
    # so nothing changes visually vs. before
    monitor = 0
    follow = none
    width = 300
    height = (0, 300)
    origin = top-right
    offset = (10, 50)
    notification_limit = 20
    font = pango:DejaVu Sans Mono 18
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    frame_width = 3
    frame_color = "#aaaaaa"
    separator_color = frame
    show_age_threshold = 60
    stack_duplicates = true
    hide_duplicate_count = false
    idle_threshold = 120
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#222222"
    foreground = "#888888"
    timeout = 10
    default_icon = dialog-information

[urgency_normal]
    # from: Alacritty (Gruvbox Material Dark Hard)
    background = "#ea6962"
    foreground = "#ffffff"
    timeout = 10
    default_icon = dialog-information

[urgency_critical]
    background = "#900000"
    foreground = "#ffffff"
    frame_color = "#ff0000"
    timeout = 0
    default_icon = dialog-warning

# ─── OpenCode notification sounds ────────────────────────────────
# Match notifications from kdco/notify plugin (via node-notifier → notify-send)

[opencode-complete]
    summary = "Ready for review"
    script = ~/.config/dunst/scripts/opencode-sound.sh

[opencode-error]
    summary = "Something went wrong"
    script = ~/.config/dunst/scripts/opencode-sound.sh

[opencode-permission]
    summary = "Waiting for you"
    script = ~/.config/dunst/scripts/opencode-sound.sh

[opencode-question]
    summary = "Question for you"
    script = ~/.config/dunst/scripts/opencode-sound.sh

# Also match OpenCode/OMA-style notifications (in case they re-enable)
[opencode-oma]
    summary = "OpenCode*"
    script = ~/.config/dunst/scripts/opencode-sound.sh
