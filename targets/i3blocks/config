# i3blocks config - minimal
#
# See man i3blocks for complete reference.

command=/usr/share/i3blocks/$BLOCK_NAME
separator_block_width=15
markup=none

# Network Download
[net_down]
command=$HOME/.config/i3blocks/scripts/net_down
color=#98971a
interval=5

# Network Upload
[net_up]
command=$HOME/.config/i3blocks/scripts/net_up
color=#d65d0e
interval=5

# OpenCode Go
[opencode_go]
command=$HOME/.config/i3blocks/scripts/opencode_go
color=#689d6a
interval=300

# WiFi
[wifi]
command=$HOME/.config/i3blocks/scripts/wifi
instance=wlo1
color=#458588
interval=10

# Uptime
[uptime]
command=$HOME/.config/i3blocks/scripts/uptime
label=ůį•Ē
color=#8f3f71
interval=60

# Weather
[weather]
command=$HOME/.config/i3blocks/scripts/weather
color=#83a598
interval=3600

# Battery
[battery]
command=$HOME/.config/i3blocks/scripts/battery
label=ůįāĄ
color=#98971a
interval=60

# Volume
[volume]
label=ůįēĺ
color=#d65d0e
interval=once
signal=10

# CPU
[cpu_usage]
command=$HOME/.config/i3blocks/scripts/cpu_usage
label=ůįüÄ
color=#d79921
interval=5

# Memory
[memory]
command=$HOME/.config/i3blocks/scripts/memory
label=ůįÜľ
color=#b16286
interval=5

# Date & time
[time]
command=date '+%a %d/%b %H:%M:%S'
color=#cc241d
interval=1

# Caps Lock
[keyindicator]
command=$HOME/.config/i3blocks/scripts/keyindicator -c '#ffffff' -C '#504945'
instance=CAPS
interval=once
signal=11
