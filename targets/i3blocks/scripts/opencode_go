#!/bin/bash
set -euo pipefail
#
# Display OpenCode Go usage as percentage of $60 monthly limit.
# Requires: opencode CLI, bc
#
# Output format: 箚뙲 <percent>% $<cost>
# Fallback:       箚뙲 ?

output=$(opencode stats 2>/dev/null) || { echo "箚뙲 ?"; exit 0; }
cost=$(echo "$output" | grep -oP 'Total Cost\s+\$\K[\d.]+') || { echo "箚뙲 ?"; exit 0; }
days=$(echo "$output" | grep -oP 'Days\s+\K\d+') || { echo "箚뙲 ?"; exit 0; }
percent=$(awk "BEGIN {printf \"%d\", ($cost * 100) / 60}")
echo "箚뙲 ${days}d \$${cost} ${percent}%"
